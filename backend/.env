# Server Configuration (Development)
PORT=3002
NODE_ENV=development

# JWT Configuration
JWT_SECRET=dev-jwt-secret-key-for-testing
JWT_EXPIRES_IN=7d

# Database (Test database - separate from production)
DB_PATH=./database/rhm_test.db

# Default Admin Credentials (used for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Google Drive Backup (optional - configure when ready)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
